<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Solicitud <%= solicitud.numero_solicitud %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
  <div class="container py-5">
    <a href="/admin/dashboard" class="btn btn-outline-secondary mb-4">← Volver al panel</a>
    <div class="card shadow rounded-4 p-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h2>Solicitud <%= solicitud.numero_solicitud %></h2>
          <p class="text-muted">Creada el <%= solicitud.fecha_creacion %></p>
        </div>
        <form method="post" class="d-flex gap-2 align-items-center">
          <select name="estado" class="form-select">
            <% estados.forEach(estado => { %>
              <option value="<%= estado %>" <%= solicitud.estado === estado ? 'selected' : '' %>><%= estado %></option>
            <% }) %>
          </select>
          <button class="btn btn-success" type="submit">Guardar</button>
        </form>
      </div>
      <div class="row g-4">
        <div class="col-md-6">
          <h5>Datos personales</h5>
          <p><strong>Nombre:</strong> <%= solicitud.nombre %></p>
          <p><strong>Teléfono:</strong> <%= solicitud.telefono %></p>
          <p><strong>Email:</strong> <%= solicitud.email %></p>
          <p><strong>Dirección:</strong> <%= solicitud.direccion %></p>
        </div>
        <div class="col-md-6">
          <h5>Reporte</h5>
          <p><strong>Tipo:</strong> <%= solicitud.tipo_reporte %></p>
          <p><strong>Comentarios:</strong> <%= solicitud.comentarios %></p>
          <p><strong>Documento:</strong> <a href="<%= solicitud.documento %>" target="_blank" class="link-primary">Ver archivo</a></p>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
